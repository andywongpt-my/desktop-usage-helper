{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Desktop Usage Helper",
  "version": "0.1.0",
  "identifier": "com.andywongpt.desktop-usage-helper",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Desktop Usage Helper",
        "label": "main",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "center": true,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#0a0a0c",
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://*"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Track LLM vendor usage in one place",
    "longDescription": "Aggregates Codex, Ollama Cloud, opencode, MiniMax, and more — see remaining balance at a glance without opening a browser."
  }
}
